# secrets.fish.template — local API keys and tokens
#
# 1. Copy this file to ~/.config/fish/conf.d/secrets.fish
# 2. Replace the placeholder values with your actual keys
# 3. NEVER commit secrets.fish to git
#
# The default .gitignore in this repo excludes secrets.fish but if you're
# tracking your fish config in your own dotfiles repo, double-check.

# Anthropic — get a key at https://console.anthropic.com/settings/keys
set -gx ANTHROPIC_API_KEY "sk-ant-XXXX-replace-me"

# Optional — uncomment as needed:
# set -gx OPENAI_API_KEY    "sk-XXXX-replace-me"
# set -gx GITHUB_TOKEN      "ghp_XXXX-replace-me"
