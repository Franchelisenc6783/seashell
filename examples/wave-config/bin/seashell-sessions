#!/usr/bin/env bash
# seashell-sessions — list and resolve Claude Code sessions
#
# Reads from two sources:
#   1. ~/.seashell/sessions/<id>.json   (hook-registered sessions, with metadata)
#   2. ~/.claude/projects/*/*.jsonl     (filesystem-discovered, all sessions)
#
# The dual-source design means resume-by-name works even for sessions where
# the SessionStart hook didn't fire (e.g. claude -p invocations).
#
# Usage:
#   seashell-sessions                       — list all known sessions
#   seashell-sessions list                  — same as above
#   seashell-sessions resolve <name>        — print the best-match session id
#   seashell-sessions latest <name>         — latest session id for a project
#   seashell-sessions show <id>             — full metadata for one session

set -euo pipefail

usage() {
    cat <<'EOF'
Usage:
  seashell-sessions                  List all known Claude Code sessions
  seashell-sessions list             Same as above
  seashell-sessions resolve <name>   Print the session id whose project label
                                     best matches <name> (fuzzy)
  seashell-sessions latest <name>    Print only the most-recent session id
                                     for the matching project
  seashell-sessions primary <name>   Print the project's pinned primary session
                                     (falls back to latest if none pinned)
  seashell-sessions promote [<id>]   Pin a session as the project's primary.
                                     With no arg: when run inside a project that
                                     has .seashell-inbox/, pin the most recent
                                     session for that project. With <id>: pin
                                     that specific session id.
  seashell-sessions show <id>        Full metadata for one session
  seashell-sessions -h | --help      Show this help

Sources:
  Hook-registered:  ~/.seashell/sessions/<id>.json
  Filesystem-found: ~/.claude/projects/<encoded-cwd>/<id>.jsonl
  Primary pointer:  <project>/.seashell-inbox/primary-session.txt
EOF
}

cmd="${1:-list}"
case "$cmd" in
    -h|--help|help) usage; exit 0 ;;
esac

# All session lookup logic lives in this Python helper for clarity.
exec python3 - "$@" <<'PYEOF'
import json
import os
import sys
from datetime import datetime, timezone
from pathlib import Path

HOME = Path(os.environ["HOME"])
SEASHELL_SESSIONS = HOME / ".seashell" / "sessions"
CLAUDE_PROJECTS = HOME / ".claude" / "projects"


def decode_project_dir(name: str) -> str:
    """
    Decode the directory name Claude Code uses under ~/.claude/projects/.
    Example: '-Users-yourname-Github-MyProject' -> '/Users/yourname/Github/MyProject'
    Heuristic: leading '-' dropped, remaining '-' become '/'.
    """
    if name.startswith("-"):
        name = name[1:]
    return "/" + name.replace("-", "/")


def load_hook_registry():
    registry = {}
    if not SEASHELL_SESSIONS.is_dir():
        return registry
    for entry in SEASHELL_SESSIONS.iterdir():
        if not entry.is_file() or not entry.name.endswith(".json"):
            continue
        try:
            with entry.open() as f:
                rec = json.load(f)
        except Exception:
            continue
        if "id" in rec:
            registry[rec["id"]] = rec
    return registry


def discover_filesystem_sessions():
    if not CLAUDE_PROJECTS.is_dir():
        return []
    sessions = []
    for project_dir in CLAUDE_PROJECTS.iterdir():
        if not project_dir.is_dir():
            continue
        cwd = decode_project_dir(project_dir.name)
        label = os.path.basename(cwd) or "(unknown)"
        for jsonl in project_dir.glob("*.jsonl"):
            try:
                stat = jsonl.stat()
            except OSError:
                continue
            mtime_iso = datetime.fromtimestamp(stat.st_mtime, tz=timezone.utc).strftime(
                "%Y-%m-%dT%H:%M:%SZ"
            )
            sessions.append(
                {
                    "id": jsonl.stem,
                    "cwd": cwd,
                    "label": label,
                    "last_activity": mtime_iso,
                    "size_bytes": stat.st_size,
                    "jsonl_path": str(jsonl),
                }
            )
    return sessions


def merge_sources():
    hooks = load_hook_registry()
    fs = discover_filesystem_sessions()
    fs_by_id = {s["id"]: s for s in fs}
    merged = []
    for fs_rec in fs:
        sid = fs_rec["id"]
        merged_rec = dict(fs_rec)
        if sid in hooks:
            hook_rec = hooks[sid]
            for key in ("label", "started_at", "wave_block_id", "wave_tab_id"):
                if hook_rec.get(key):
                    merged_rec[key] = hook_rec[key]
            merged_rec["hook_registered"] = True
        else:
            merged_rec["hook_registered"] = False
        merged.append(merged_rec)
    seen_ids = {s["id"] for s in merged}
    for sid, rec in hooks.items():
        if sid in seen_ids:
            continue
        merged.append({**rec, "hook_registered": True, "last_activity": rec.get("started_at", "")})
    merged.sort(key=lambda s: s.get("last_activity", ""), reverse=True)
    return merged


def fuzzy_match(query, sessions):
    q = query.lower().strip()
    # Strip leading articles/possessives — "the weather app" should
    # match the same set as "weather app".
    for stop in ("the ", "our ", "my ", "this ", "that "):
        if q.startswith(stop):
            q = q[len(stop):].strip()
            break
    # Normalised: collapse spaces/dashes/underscores so "weather app"
    # matches "weatherapp" matches "weather-app".
    q_norm = "".join(c for c in q if c.isalnum())
    scored = []
    for s in sessions:
        label = s.get("label", "").lower()
        label_norm = "".join(c for c in label if c.isalnum())
        cwd = s.get("cwd", "").lower()
        score = 0
        if q == label:
            score = 100
        elif q_norm and q_norm == label_norm:
            score = 95           # "weather app" == "weatherapp"
        elif label.startswith(q):
            score = 85
        elif q in label:
            score = 75
        elif label.replace("-", "") == q.replace("-", ""):
            score = 90
        elif q_norm and len(q_norm) >= 4 and q_norm in label_norm:
            score = 80           # multi-word query is a substring of label
        elif label_norm and len(label_norm) >= 4 and label_norm in q_norm:
            # Catches verbose phrasings: query "the work I was doing on the
            # auth refactor" contains label_norm "authrefactor", so we still
            # find the project. 4-char minimum prevents tiny labels like "ai"
            # or "cv" from matching half of all queries.
            score = 70
        elif q in cwd:
            score = 50
        if not score:
            initials = "".join(c for c in s.get("label", "") if c.isupper()).lower()
            if initials and initials == q:
                score = 95
        if score > 0:
            scored.append((score, s))
    # Sort by score desc, then activity desc
    scored.sort(key=lambda t: (t[0], t[1].get("last_activity", "")), reverse=True)
    return [s for _, s in scored]


def cmd_list():
    sessions = merge_sources()
    if not sessions:
        print("📭 No Claude Code sessions found.")
        print("   Start one with: claude   (in any directory)")
        return
    print(f"📋 Active Claude Code sessions ({len(sessions)}):\n")
    print(f"  {'LABEL':<28} {'LAST ACTIVITY':<22} {'ID (short)':<12} CWD")
    print(f"  {'-' * 28} {'-' * 22} {'-' * 12} {'-' * 30}")
    for s in sessions[:30]:
        label = s.get("label", "?")[:28]
        last = s.get("last_activity", "")[:22]
        sid = s["id"][:8]
        cwd = s.get("cwd", "?")
        marker = "★" if s.get("hook_registered") else " "
        print(f"  {label:<28} {last:<22} {sid:<12} {cwd} {marker}")
    if len(sessions) > 30:
        print(f"\n  ... {len(sessions) - 30} more")
    print("\n  ★ = registered via SessionStart hook (interactive Wave session)")


def cmd_resolve(query, latest_only=False):
    sessions = merge_sources()
    matches = fuzzy_match(query, sessions)
    if not matches:
        print(f"✗ No session matched '{query}'", file=sys.stderr)
        sys.exit(1)
    if latest_only or len(matches) > 1:
        if not latest_only and len(matches) > 1:
            print(f"  ⚠ {len(matches)} sessions matched '{query}' — picking most recent:", file=sys.stderr)
            for m in matches[:5]:
                print(f"     {m.get('label')} ({m['id'][:8]}) — {m.get('last_activity')}", file=sys.stderr)
        best = sorted(matches, key=lambda s: s.get("last_activity", ""), reverse=True)[0]
        print(best["id"])
    else:
        print(matches[0]["id"])


def cmd_show(session_id):
    sessions = merge_sources()
    for s in sessions:
        if s["id"] == session_id or s["id"].startswith(session_id):
            print(json.dumps(s, indent=2))
            return
    print(f"✗ No session matched id '{session_id}'", file=sys.stderr)
    sys.exit(1)


# ── Primary-session pointer helpers ───────────────────────────────────────────
# A project's primary session is recorded at:
#   <project>/.seashell-inbox/primary-session.txt
# It contains a single line — the session UUID. This is what
# `hey continue with <project>` resumes by default.

def find_inbox_for_cwd(cwd):
    """Walk up from cwd looking for a .seashell-inbox/ directory."""
    p = Path(cwd).resolve()
    while True:
        inbox = p / ".seashell-inbox"
        if inbox.is_dir():
            return inbox
        if p.parent == p:
            return None
        p = p.parent


def find_inbox_for_project(name):
    """Find the .seashell-inbox/ for a project matched by name."""
    sessions = merge_sources()
    matches = fuzzy_match(name, sessions)
    if not matches:
        return None, None
    best = sorted(matches, key=lambda s: s.get("last_activity", ""), reverse=True)[0]
    cwd = best.get("cwd")
    if not cwd:
        return None, best
    inbox = Path(cwd) / ".seashell-inbox"
    if not inbox.is_dir():
        return None, best
    return inbox, best


def read_primary(inbox):
    pointer = inbox / "primary-session.txt"
    if not pointer.is_file():
        return None
    sid = pointer.read_text().strip()
    return sid or None


def write_primary(inbox, session_id):
    pointer = inbox / "primary-session.txt"
    pointer.write_text(session_id + "\n")


def cmd_primary(query):
    """Print the primary session id for the named project.
    Falls back to the most recent session if no primary pinned."""
    inbox, best = find_inbox_for_project(query)
    if inbox:
        sid = read_primary(inbox)
        if sid:
            print(sid)
            return
    # Fall back to latest matching session
    if best:
        print(best["id"])
        return
    print(f"✗ No project matched '{query}'", file=sys.stderr)
    sys.exit(1)


def cmd_promote(args):
    """Pin a session as the project's primary.
    With no args: pin the most-recent session for the project at $PWD.
    With <id>: pin <id> (inferring the project from its cwd)."""
    sessions = merge_sources()

    if not args:
        # No id given — must be inside a project with .seashell-inbox/
        inbox = find_inbox_for_cwd(os.getcwd())
        if not inbox:
            print("✗ No .seashell-inbox/ found at or above " + os.getcwd(), file=sys.stderr)
            print("  Run `seashell-init` here first, or pass a session id.", file=sys.stderr)
            sys.exit(1)
        project_root = str(inbox.parent)
        # Find the most-recent session whose cwd matches this project
        candidates = [s for s in sessions if s.get("cwd", "").rstrip("/") == project_root.rstrip("/")]
        if not candidates:
            print(f"✗ No sessions found for {project_root}", file=sys.stderr)
            sys.exit(1)
        candidates.sort(key=lambda s: s.get("last_activity", ""), reverse=True)
        chosen = candidates[0]
        write_primary(inbox, chosen["id"])
        print(f"✓ Pinned {chosen['id'][:8]} as primary for {Path(project_root).name}")
        print(f"  ({inbox / 'primary-session.txt'})")
        return

    # An id (or prefix) was given — find it, then locate its project
    sid_query = args[0]
    chosen = None
    for s in sessions:
        if s["id"] == sid_query or s["id"].startswith(sid_query):
            chosen = s
            break
    if not chosen:
        print(f"✗ No session matched id '{sid_query}'", file=sys.stderr)
        sys.exit(1)
    cwd = chosen.get("cwd")
    if not cwd:
        print(f"✗ Session {chosen['id'][:8]} has no recorded cwd", file=sys.stderr)
        sys.exit(1)
    inbox = Path(cwd) / ".seashell-inbox"
    if not inbox.is_dir():
        print(f"✗ {cwd} is not Seashell-initialised (no .seashell-inbox/).", file=sys.stderr)
        print(f"  Run: cd {cwd} && seashell-init", file=sys.stderr)
        sys.exit(1)
    write_primary(inbox, chosen["id"])
    print(f"✓ Pinned {chosen['id'][:8]} as primary for {Path(cwd).name}")
    print(f"  ({inbox / 'primary-session.txt'})")


cmd = sys.argv[1] if len(sys.argv) > 1 else "list"
args = sys.argv[2:]

if cmd in ("list", "ls"):
    cmd_list()
elif cmd == "resolve":
    if not args:
        print("Usage: seashell-sessions resolve <name>", file=sys.stderr); sys.exit(1)
    cmd_resolve(" ".join(args))
elif cmd == "latest":
    if not args:
        print("Usage: seashell-sessions latest <name>", file=sys.stderr); sys.exit(1)
    cmd_resolve(" ".join(args), latest_only=True)
elif cmd == "primary":
    if not args:
        print("Usage: seashell-sessions primary <name>", file=sys.stderr); sys.exit(1)
    cmd_primary(" ".join(args))
elif cmd == "promote":
    cmd_promote(args)
elif cmd == "show":
    if not args:
        print("Usage: seashell-sessions show <id>", file=sys.stderr); sys.exit(1)
    cmd_show(args[0])
else:
    print(f"Unknown command: {cmd}", file=sys.stderr); sys.exit(1)
PYEOF
