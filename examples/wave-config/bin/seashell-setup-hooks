#!/usr/bin/env bash
# seashell-setup-hooks — install the Seashell hooks into Claude Code's settings.
#
# Adds SessionStart and PostToolUse hook entries to ~/.claude/settings.json.
# Idempotent: skips entries that are already present.
#
# Run once after installing the wave-config bundle.

set -euo pipefail

SETTINGS="$HOME/.claude/settings.json"
SS_HOOK="$HOME/.local/bin/seashell-session-start"
PT_HOOK="$HOME/.local/bin/seashell-post-tool-use"

say()  { printf '\033[36m▶\033[0m %s\n' "$*"; }
ok()   { printf '\033[32m✓\033[0m %s\n' "$*"; }
err()  { printf '\033[31m✗\033[0m %s\n' "$*" >&2; }

# Verify the hook scripts are installed
for h in "$SS_HOOK" "$PT_HOOK"; do
    if [ ! -x "$h" ]; then
        err "hook script not executable or missing: $h"
        echo ""
        echo "Hint: run examples/wave-config/install.sh first to install the hook scripts."
        exit 1
    fi
done

# Make sure the settings file exists
mkdir -p "$(dirname "$SETTINGS")"
if [ ! -f "$SETTINGS" ]; then
    printf '{}\n' > "$SETTINGS"
fi

# Backup before mutating
cp "$SETTINGS" "$SETTINGS.backup-$(date +%Y%m%d-%H%M%S)"

# Use Python for safe JSON merge (preserves user's existing keys)
# Hook config schema (verified empirically against Claude Code 2.1.119+):
#   Every event entry has the form
#       {"matcher": "<pattern>", "hooks": [{"type": "command", "command": "<path>"}]}
#   For SessionStart, valid matchers are: "startup", "resume", "clear", "compact"
#   For PostToolUse, the matcher is a tool-name regex; ".*" matches all tools.
#
# This script is idempotent: it removes any old-format entries and rewrites
# the SeaShell entries to the correct schema. Other users' hook entries are
# preserved.
python3 - "$SETTINGS" "$SS_HOOK" "$PT_HOOK" <<'PYEOF'
import json, sys
path, ss_hook, pt_hook = sys.argv[1], sys.argv[2], sys.argv[3]

with open(path) as f:
    settings = json.load(f)

settings.setdefault("hooks", {})


def is_seashell_entry(entry, target_command):
    """Detect a SeaShell hook entry in either correct or old (broken) format."""
    if not isinstance(entry, dict):
        return False
    # Correct format: matcher + hooks array
    hooks_arr = entry.get("hooks")
    if isinstance(hooks_arr, list):
        return any(
            isinstance(h, dict) and h.get("command") == target_command
            for h in hooks_arr
        )
    # Legacy/broken format: type + command + matcher at top level
    return entry.get("command") == target_command


def normalize_event(event_name, target_command, matchers_to_install):
    """
    Strip any seashell entries (old or new format) for this event,
    then insert correct-format entries for each desired matcher.
    Preserves any non-seashell entries.
    """
    existing = settings["hooks"].get(event_name, [])
    if isinstance(existing, dict):
        existing = [existing]

    # Drop seashell entries (regardless of format)
    cleaned = [e for e in existing if not is_seashell_entry(e, target_command)]

    # Add correct-format entry for each matcher
    for matcher in matchers_to_install:
        cleaned.append({
            "matcher": matcher,
            "hooks": [{"type": "command", "command": target_command}],
        })

    settings["hooks"][event_name] = cleaned
    return len(matchers_to_install)


# SessionStart: register for both startup and resume
ss_added = normalize_event("SessionStart", ss_hook, ["startup", "resume"])

# PostToolUse: matcher='.*' fires for every tool
pt_added = normalize_event("PostToolUse", pt_hook, [".*"])

with open(path, "w") as f:
    json.dump(settings, f, indent=2)
    f.write("\n")

print(f"✓ SessionStart: {ss_added} matcher entries installed (startup + resume)")
print(f"✓ PostToolUse:  {pt_added} matcher entry installed (.*)")
PYEOF

ok "Hooks configured at $SETTINGS"
echo ""
echo "Next time you run \`claude\` (in any directory), the hooks will fire and"
echo "Seashell will register the session at ~/.seashell/sessions/<id>.json."
echo ""
echo "Backup saved to: $(ls -t "$SETTINGS".backup-* 2>/dev/null | head -1)"
